{
    "name": "greeneffect/contao-content-visibility",
    "description": "Restrict tl_content visibility in Contao back end based on back end user groups.",
    "type": "contao-bundle",
    "license": "CC-BY-SA-4.0",
    "keywords": [
        "contao",
        "contao-bundle",
        "contao5",
        "cms",
        "backend",
        "access-control",
        "user-groups",
        "php",
        "symfony",
        "tl_content"
    ],
    "homepage": "https://github.com/GreenEffect/contao-content-visibility",
    "authors": [
        {
            "name": "Green Effect",
            "email": "contact@green-effect.fr"
        }
    ],
    "support": {
        "issues": "https://github.com/GreenEffect/contao-content-visibility/issues",
        "source": "https://github.com/GreenEffect/contao-content-visibility"
    },
    "require": {
        "php": "^8.1",
        "contao/core-bundle": "^5.3",
        "contao/manager-plugin": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Greeneffect\\ContaoContentVisibility\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Greeneffect\\ContaoContentVisibility\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "contao/manager-plugin": true
        }
    },
    "extra": {
        "contao-manager-plugin": "Greeneffect\\ContaoContentVisibility\\ContaoManager\\Plugin"
    }
}
